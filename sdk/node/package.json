{
  "name": "@a3s-lab/box",
  "version": "1.8.5",
  "description": "Node.js bindings for A3S Box MicroVM sandbox runtime",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "files": [
    "index.js",
    "index.d.ts",
    "*.node",
    "package.json",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/A3S-Lab/Box",
    "directory": "sdk/node"
  },
  "napi": {
    "name": "a3s-box",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-unknown-linux-gnu",
        "aarch64-unknown-linux-musl"
      ]
    }
  },
  "optionalDependencies": {
    "@a3s-lab/box-darwin-arm64": "0.7.0",
    "@a3s-lab/box-linux-x64-gnu": "0.7.0",
    "@a3s-lab/box-linux-x64-musl": "0.7.0",
    "@a3s-lab/box-linux-arm64-gnu": "0.7.0",
    "@a3s-lab/box-linux-arm64-musl": "0.7.0"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  },
  "scripts": {
    "build": "napi build --platform --release",
    "prepublishOnly": "napi prepublish -t npm",
    "artifacts": "napi artifacts",
    "version": "napi version"
  }
}
